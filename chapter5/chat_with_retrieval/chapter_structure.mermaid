graph TB
    subgraph Document Processing
        A[Source Documents] --> B[Text Chunking]
        B --> C[Document Embeddings]
    end

    subgraph Vector Database
        C --> D[Vector Store]
        D --> E[Vector Index]
    end

    subgraph RAG Core Process
        Q[User Query] --> R[Query Embedding]
        R --> S[Similarity Search]
        E --> S
        S --> T[Retrieved Context]
        T --> U[Prompt Construction]
        U --> V[LLM Response]
    end

    subgraph Embedding Models
        M[Embedding Model] --> C
        M --> R
    end

    style Q fill:#f9f,stroke:#333
    style M fill:#bbf,stroke:#333
    style D fill:#bfb,stroke:#333
    style E fill:#fbb,stroke:#333
    style V fill:#ff9,stroke:#333

